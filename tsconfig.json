{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,

    /* Strictness Enhancements */
    "noImplicitAny": true, // Error on expressions and declarations with an implied 'any' type.
    "noUnusedLocals": true, // Report errors on unused local variables.
    "noImplicitReturns": true, // Ensure all code paths in a function return a value.
    "noFallthroughCasesInSwitch": true, // Report errors for fallthrough cases in switch statements.
    "exactOptionalPropertyTypes": true, // Ensures optional properties are strictly matched (no 'undefined' if not allowed).
    "noImplicitOverride": true, // Ensure overrides are explicitly marked with the 'override' keyword.
    "useUnknownInCatchVariables": true // Changes the type of variables in catch clauses from 'any' to 'unknown'.
  },
  "include": ["src/**/*", "workers/**/*", "scripts/**/*"]
}
